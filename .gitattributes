# Normalize all text files to LF in the repo, check out as LF everywhere.
* text=auto eol=lf

# Source code
*.c         text eol=lf
*.cu        text eol=lf
*.h         text eol=lf
*.cuh       text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf

# Scripts
*.sh        text eol=lf
*.bash      text eol=lf
*.py        text eol=lf

# Build
Makefile    text eol=lf
*.mk        text eol=lf
*.cmake     text eol=lf
CMakeLists.txt text eol=lf

# Config
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf

# Windows-specific (keep CRLF)
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.sln       text eol=crlf
*.vcxproj   text eol=crlf

# Binary (no normalization)
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.exe       binary
*.dll       binary
*.lib       binary
*.a         binary
*.o         binary
*.so        binary
*.dylib     binary
*.docx      binary
*.drawio    binary
